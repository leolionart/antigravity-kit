            "args": [],
            "disabled": false,
            "env": {
                "CONFLUENCE_URL": "https://docs.vexere.net",
                "CONFLUENCE_PERSONAL_TOKEN": "YOUR_API_KEY", // Vào profile -> Personal Access Tokens -> Create
                "JIRA_URL": "https://jira.vexere.net",

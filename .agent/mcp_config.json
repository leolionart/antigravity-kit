{
    "mcpServers": {
        "mcp-atlassian": {
            "command": "npx",
            "args": [
                "-y",
                "-p",
                "jsdom",
                "-p",
                "mcp-atlassian",
                "mcp-atlassian"
            ],
            "disabled": true,
            "env": {
                "CONFLUENCE_URL": "https://docs.vexere.net",
                "CONFLUENCE_PERSONAL_TOKEN": "YOUR_API_KEY",
                "JIRA_URL": "https://jira.vexere.net",
                "JIRA_PERSONAL_TOKEN": "YOUR_API_KEY"
            }
        },
        "HubSpotDev": {
            "command": "npx",
            "args": [
                "-y",
                "-p",
                "@hubspot/cli",
                "hs",
                "mcp",
                "start",
                "--ai-agent",
                "gemini"
            ],
            "env": {
                "HUBSPOT_MCP_STANDALONE": "true"
            }
        }
    }
}
#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
PROXY="$ROOT_DIR/.agent/.shared/atlassian-mcp"
SUBCOMMAND="${1:-}"

usage() {
  cat <<'USAGE'
Usage: ./.agent/skills/jira-task-manager/helpers/jira-mcp <jira-subcommand> [args]

Examples:
  ./.agent/skills/jira-task-manager/helpers/jira-mcp jira-search --jql "project = AI" --limit 5 --output json
  ./.agent/skills/jira-task-manager/helpers/jira-mcp jira-get-issue --issue-key AI-123 --output json
USAGE
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$SUBCOMMAND" in
  -h|--help)
    usage
    exit 0
    ;;
esac

ARGS=("$@")

has_flag() {
  local flag="$1"
  shift || true
  local item
  for item in "$@"; do
    if [[ "$item" == "$flag" || "$item" == "$flag="* ]]; then
      return 0
    fi
  done
  return 1
}

if [[ "${ATLASSIAN_CLI_LEAN:-1}" == "1" ]] && ! has_flag "--fields" "${ARGS[@]}"; then
  DEFAULT_FIELDS="${ATLASSIAN_JIRA_LEAN_FIELDS:-key,summary,status,assignee,priority,issuetype,updated}"
  case "$SUBCOMMAND" in
    jira-search|jira-get-sprint-issues|jira-get-board-issues|jira-get-project-issues)
      ARGS+=(--fields "$DEFAULT_FIELDS")
      ;;
    jira-get-issue)
      ISSUE_FIELDS="$DEFAULT_FIELDS"
      if [[ ",$ISSUE_FIELDS," == *",key,"* ]]; then
        ISSUE_FIELDS="${ISSUE_FIELDS//key,}"
        ISSUE_FIELDS="${ISSUE_FIELDS//,key/}"
        ISSUE_FIELDS="${ISSUE_FIELDS#,}"
        ISSUE_FIELDS="${ISSUE_FIELDS%,}"
      fi
      ARGS+=(--fields "${ISSUE_FIELDS:-summary,status,assignee,priority,issuetype,updated}")
      ;;
  esac
fi

exec "$PROXY" "${ARGS[@]}"

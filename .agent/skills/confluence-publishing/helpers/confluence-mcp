#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
PROXY="$ROOT_DIR/.agent/.shared/atlassian-mcp"

usage() {
  cat <<'USAGE'
Usage: ./.agent/skills/confluence-publishing/helpers/confluence-mcp <confluence-subcommand> [args]

Examples:
  ./.agent/skills/confluence-publishing/helpers/confluence-mcp confluence-get-page --page-id 193248579 --output json
  ./.agent/skills/confluence-publishing/helpers/confluence-mcp confluence-search --query 'title ~ "Bot Quality"' --limit 5 --output json
USAGE
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

exec "$PROXY" "$@"
